# Whisper Service Configuration

# Service settings
WHISPER_PORT=9000
WHISPER_HOST=0.0.0.0
WHISPER_MODEL_SIZE=small

# GPU settings (if available)
CUDA_VISIBLE_DEVICES=0
TORCH_CUDNN_V8_API_DISABLED=1
TOKENIZERS_PARALLELISM=false

# Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Model options: tiny, base, small, medium, large-v2, large-v3
# Larger models provide better accuracy but require more VRAM
# small: ~461MB VRAM, good balance of speed/accuracy
# medium: ~1.42GB VRAM, better accuracy
# large-v3: ~2.87GB VRAM, best accuracy