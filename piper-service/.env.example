# Piper TTS Service Configuration
# Copy this file to .env and customize for your environment

# Server Configuration
PIPER_HOST=0.0.0.0
PIPER_PORT=9001

# Model Configuration
PIPER_MODELS_DIR=models/piper
PIPER_DEFAULT_VOICE=en_US-lessac-medium
PIPER_MAX_TEXT_LENGTH=10000

# Performance Settings
PIPER_MAX_CONCURRENT=10
PIPER_MODEL_CACHE_SIZE=5

# Logging Configuration
LOG_LEVEL=INFO
PIPER_LOG_FILE=logs/piper-service.log