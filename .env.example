# Blindr Services Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# SERVICE PORTS
# =============================================================================
# Whisper Speech-to-Text Service
WHISPER_PORT=9000
# Piper Text-to-Speech Service
PIPER_PORT=9001

# =============================================================================
# WHISPER SERVICE CONFIGURATION
# =============================================================================
# Whisper model size: tiny, base, small, medium, large-v2, large-v3
# Larger models are more accurate but use more GPU memory
WHISPER_MODEL_SIZE=small

# In-container log path for whisper-service (compose already sets this; documented for completeness)
WHISPER_LOG_FILE=/app/logs/whisper-service.log

# GPU Configuration
# Set to specific GPU ID (0, 1, etc.) or "all" to use all GPUs
# Leave empty to auto-detect
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# PIPER SERVICE CONFIGURATION
# =============================================================================
# Default voice for TTS (see voice catalog in service)
PIPER_DEFAULT_VOICE=en_US-amy-medium

# Maximum text length for single TTS request (characters)
PIPER_MAX_TEXT_LENGTH=10000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: debug, info, warning, error
LOG_LEVEL=info

# =============================================================================
# SECURITY SETTINGS (for production)
# =============================================================================
# SSL certificate paths (for nginx proxy)
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Docker resource limits
WHISPER_MEMORY_LIMIT=8G
PIPER_MEMORY_LIMIT=4G
PIPER_CPU_LIMIT=2.0
