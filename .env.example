# Blindr Services Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# SERVICE PORTS
# =============================================================================
# Whisper Speech-to-Text Service
WHISPER_PORT=9000
# Piper Text-to-Speech Service  
PIPER_PORT=9001
# Nginx Reverse Proxy (production)
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
# Prometheus Monitoring (optional)
PROMETHEUS_PORT=9090

# =============================================================================
# WHISPER SERVICE CONFIGURATION
# =============================================================================
# Whisper model size: tiny, base, small, medium, large-v2, large-v3
# Larger models are more accurate but use more GPU memory
WHISPER_MODEL_SIZE=small

# GPU Configuration
# Set to specific GPU ID (0, 1, etc.) or "all" to use all GPUs
# Leave empty to auto-detect
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# PIPER SERVICE CONFIGURATION
# =============================================================================
# Default voice for TTS (see voice catalog in service)
PIPER_DEFAULT_VOICE=en_US-amy-medium

# Maximum text length for single TTS request (characters)
PIPER_MAX_TEXT_LENGTH=10000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: debug, info, warning, error
LOG_LEVEL=info

# =============================================================================
# DATA PERSISTENCE PATHS
# =============================================================================
# Where to store model files and logs on the host
# These directories will be created automatically if they don't exist

# Whisper data paths
WHISPER_MODELS_PATH=./data/whisper/models
WHISPER_LOGS_PATH=./data/whisper/logs

# Piper data paths
PIPER_MODELS_PATH=./data/piper/models
PIPER_LOGS_PATH=./data/piper/logs
PIPER_CACHE_PATH=./data/piper/cache

# =============================================================================
# SECURITY SETTINGS (for production)
# =============================================================================
# SSL certificate paths (for nginx proxy)
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem

# API Keys (if implementing authentication)
# WHISPER_API_KEY=your-secret-key-here
# PIPER_API_KEY=your-secret-key-here

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Docker resource limits
WHISPER_MEMORY_LIMIT=8G
PIPER_MEMORY_LIMIT=4G
PIPER_CPU_LIMIT=2.0

# Worker processes (for high load scenarios)
WHISPER_WORKERS=1
PIPER_WORKERS=2

# =============================================================================
# DEVELOPMENT/DEBUG SETTINGS
# =============================================================================
# Set to 'true' to enable development features
DEBUG_MODE=false

# Enable detailed API logging
ENABLE_API_LOGGING=false

# Enable performance metrics
ENABLE_METRICS=false